	(text ".PARAM  a=15.9 \n.PARAM  fpar24=1.5e-010\n.PARAM  fpar25=1.0e-010\n.PARAM  fpar26=5.14e-012\n.PARAM  fpar27=1.6e-015\n.PARAM  fpar28=6e-013\n.PARAM  fpar29=1.15e-011\n.PARAM  fpar30=4e-013\n.PARAM  fpar31=25e-014\n.PARAM  fpar32=90\n.PARAM  Cdg1={fpar24*a+fpar25*SQRT(a)}\n.PARAM  Cdg2={fpar26*a}\n.PARAM  CdgV1={fpar27*a}\n.PARAM  CdgV2={(fpar31*a+fpar28)}\n.PARAM  CAP_eedg=-0.556\n.PARAM  x0={(fpar29-fpar26)/fpar30}  \n.PARAM  x1={fpar29/fpar30} \n.PARAM  dx={x1-x0}\n.FUNC 	QCdg1(x) {Cdg2*min(x,x1)+CdgV2*max(x-x1,0)\n        ++CdgV1/2*max(0, x-fpar32)**2+(Cdg2-CdgV2)\n        +*((limit(x,x0,x1)-x0)**3/(dx*dx)*((limit(x,x0,x1)-x0)\n        +/(2*dx)-1))}"
		(exclude_from_sim no)
		(at 170.688 100.33 0)
		(effects
			(font
				(face "Consolas")
				(size 1 1)
			)
			(justify left bottom)
		)
		(uuid "279f4af4-2b20-4419-9725-960b180235f9")
	)
	(text ".control\nlet ac_data = cvector(501)\nlet dc_bias = 0\nlet index = 0\nwhile index <= 500\n  alter Vd1g1 dc_bias\n  ac lin 1 250k 250k\n  let ac_data[index] = ac_data[index] + Vd1g1#branch\n  destroy ac1\n  let dc_bias = dc_bias + 1\n  let index = index + 1\nend\nwrite cdg_kicad.raw ac_data\n.endc"
		(exclude_from_sim no)
